generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────

enum UserRole {
  OWNER
  MANAGER
  CASHIER
  KITCHEN
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
}

enum OrderStatus {
  PENDING // รอส่งครัว
  CONFIRMED // ส่งครัวแล้ว
  PREPARING // กำลังทำ
  READY // เสร็จแล้ว รอเสิร์ฟ
  SERVED // เสิร์ฟแล้ว
  COMPLETED // ชำระเงินแล้ว
  CANCELLED // ยกเลิก
}

enum OrderItemStatus {
  PENDING
  PREPARING
  DONE
  VOIDED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  SELF_ORDER // จาก QR self-order
  DELIVERY // Phase 2
}

enum PaymentMethod {
  CASH
  PROMPTPAY
  CREDIT_CARD
  DEBIT_CARD
  TRUE_MONEY // Phase 2
  LINE_PAY // Phase 2
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
  PARTIAL_REFUND
}

enum StockLogReason {
  ORDER_DEDUCT // ตัดจากออเดอร์
  MANUAL_ADD // เพิ่ม stock manual
  MANUAL_DEDUCT // ลด stock manual
  VOID_RESTORE // คืน stock เมื่อ void
  ADJUSTMENT // ปรับ stock รอบนับ
}

enum ModifierType {
  SINGLE_SELECT // เลือกได้ 1 อย่าง (เช่น size)
  MULTI_SELECT // เลือกได้หลายอย่าง (เช่น topping)
}

enum TableSessionStatus {
  OPEN
  CLOSED
}

enum QueueStatus {
  WAITING
  CALLED
  DONE
  SKIPPED
}

enum PointType {
  EARN
  REDEEM
  EXPIRE
  ADJUST
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum CouponType {
  PERCENT_DISCOUNT // ลด %
  FIXED_DISCOUNT // ลดจำนวนเงิน
  FREE_ITEM // แถมเมนู (Phase 2)
}

enum CouponTargetType {
  PUBLIC // ใครก็ใช้ได้ถ้ามี code
  MEMBER_TIER // เฉพาะ tier นั้น
  MEMBER_NEW // สมาชิกใหม่ (ใช้ได้ครั้งเดียว)
  MEMBER_FIRST_ORDER // order แรกของ member
  PHYSICAL_QR // QR ที่พิมพ์แจก
}

enum AdminRole {
  SUPER_ADMIN
  SUPPORT
  BILLING
}

model AdminUser {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  name        String
  adminRole   AdminRole @default(SUPPORT)
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  auditLogs AuditLog[]

  @@map("admin_users")
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  tenantId  String?
  payload   Json     @default("{}")
  ipAddress String?
  createdAt DateTime @default(now())

  admin AdminUser @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([tenantId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Coupon {
  id             String           @id @default(cuid())
  tenantId       String
  code           String // "WELCOME10", "SUMMER20"
  name           String // "ส่วนลด 10% สมาชิกใหม่"
  type           CouponType
  targetType     CouponTargetType
  value          Decimal          @db.Decimal(10, 2) // 10 = 10% หรือ 50 = ฿50
  minOrderAmt    Decimal?         @db.Decimal(10, 2) // ขั้นต่ำ
  maxDiscountAmt Decimal?         @db.Decimal(10, 2) // cap สำหรับ PERCENT
  tierId         String? // ถ้า targetType = MEMBER_TIER
  usageLimit     Int? // null = ไม่จำกัด (total)
  usagePerMember Int?             @default(1) // ต่อ member
  usedCount      Int              @default(0)
  isActive       Boolean          @default(true)
  startsAt       DateTime?
  expiresAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  tenant Tenant             @relation(fields: [tenantId], references: [id])
  tier   LoyaltyTierConfig? @relation(fields: [tierId], references: [id])
  usages CouponUsage[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("coupons")
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String
  orderId   String
  accountId String? // null = guest ใช้
  discount  Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  order   Order           @relation(fields: [orderId], references: [id])
  coupon  Coupon          @relation(fields: [couponId], references: [id])
  account LoyaltyAccount? @relation(fields: [accountId], references: [id])

  @@index([couponId])
  @@index([accountId])
  @@map("coupon_usages")
}

// ─── MULTI-TENANCY ───────────────────────────────────────

model Tenant {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique // ใช้เป็น subdomain: {slug}.pos.app
  plan          String    @default("starter") // starter | pro | enterprise
  trialEndsAt   DateTime?
  isActive      Boolean   @default(true)
  suspendedAt   DateTime?
  suspendReason String?
  /// settings schema:
  /// {
  ///   "coupon": {
  ///     "enabled": boolean,
  ///     "maxPerOrder": number,        // default 1
  ///     "stackWithPoints": boolean,   // default false
  ///     "stackBetweenCoupons": boolean // default false
  ///   },
  ///   "loyalty": {
  ///     "earnRate": number,
  ///     "earnPer": number,
  ///     "redeemRate": number,
  ///     "minRedeemPoints": number,
  ///     "pointExpireMonths": number | null
  ///   }
  /// }
  settings      Json      @default("{}") // JSON config ต่างๆ
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  branches           Branch[]
  // users              User[]
  memberships        TenantMembership[]
  categories         Category[]
  menuItems          MenuItem[]
  modifiers          Modifier[]
  // customers          Customer[]
  loyaltyAccounts    LoyaltyAccount[]
  loyaltyTierConfigs LoyaltyTierConfig[]
  roles              Role[]
  coupons            Coupon[]

  @@map("tenants")
}

// ─── BRANCH ──────────────────────────────────────────────

model Branch {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  address      String?
  phone        String?
  timezone     String   @default("Asia/Bangkok")
  currency     String   @default("THB")
  taxRate      Decimal  @default(0) @db.Decimal(5, 4) // เช่น 0.07 = 7%
  isActive     Boolean  @default(true)
  currentQueue Int      @default(0)
  settings     Json     @default("{}") // printer config, receipt template ฯลฯ
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Self-order config
  selfOrderEnabled    Boolean @default(false)
  payLaterEnabled     Boolean @default(false) // order now, pay later
  payAtCounterEnabled Boolean @default(false) // order & pay ที่เคาน์เตอร์
  payOnlineEnabled    Boolean @default(true) // order & pay online

  // Queue config (มีอยู่แล้ว)
  queueEnabled     Boolean @default(false)
  queueDisplayName Boolean @default(false) // true = เรียกชื่อ, false = เรียกเลข

  // Loyalty config (ย้ายออกจาก tenant.settings มาเป็น field ชัดเจน)
  loyaltyEnabled Boolean @default(false)

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tables            Table[]
  orders            Order[]
  shifts            Shift[]
  // users             User[]
  memberships       TenantMembership[]
  queueTickets      QueueTicket[]
  pointTransactions PointTransaction[]

  @@index([tenantId])
  @@map("branches")
}

// ─── USERS ───────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  // tenantId     String
  // branchId     String? // null = ทุกสาขา
  name      String
  email     String?  @unique
  // pinCode      String? // 4-6 digit PIN สำหรับ void/manager action
  // tokenVersion Int      @default(0)
  // role         UserRole @default(CASHIER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // roleId       String?

  // tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // branch Branch? @relation(fields: [branchId], references: [id])
  // orders Order[] @relation("CashierOrders")
  // shifts Shift[]
  // role   Role?   @relation(fields: [roleId], references: [id])

  memberships TenantMembership[]

  // @@unique([tenantId, email])
  // @@index([tenantId])
  // @@index([branchId])
  @@map("users")
}

// ── TENANT MEMBERSHIP (role + permission ต่อ tenant) ──
model TenantMembership {
  id           String    @id @default(cuid())
  userId       String
  tenantId     String
  branchId     String? // null = ทุกสาขา
  roleId       String?
  pinCode      String? // PIN ต่อ tenant (OWNER ร้าน A มี PIN ต่างกับ ร้าน B)
  tokenVersion Int       @default(0) // ย้ายมาจาก User
  isActive     Boolean   @default(true)
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id])
  role   Role?   @relation(fields: [roleId], references: [id], onDelete: SetNull)
  orders Order[] @relation("CashierOrders")
  shifts Shift[]

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
  @@map("tenant_memberships")
}

// ─── MENU ────────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  nameEn    String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  menuItems MenuItem[]

  @@index([tenantId])
  @@map("categories")
}

model MenuItem {
  id          String   @id @default(cuid())
  tenantId    String
  categoryId  String
  name        String
  nameEn      String?
  description String?
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?
  isAvailable Boolean  @default(true)
  stockQty    Int? // null = ไม่ track stock
  stockAlert  Int?     @default(5) // แจ้งเตือนเมื่อเหลือต่ำกว่านี้
  sortOrder   Int      @default(0)
  tags        String[] @default([]) // เช่น ["bestseller", "spicy", "vegan"]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category   Category    @relation(fields: [categoryId], references: [id])
  modifiers  Modifier[]
  orderItems OrderItem[]
  stockLogs  StockLog[]

  @@index([tenantId])
  @@index([categoryId])
  @@map("menu_items")
}

model Modifier {
  id         String       @id @default(cuid())
  tenantId   String
  menuItemId String
  name       String // เช่น "ความหวาน", "Size", "Topping"
  type       ModifierType @default(SINGLE_SELECT)
  isRequired Boolean      @default(false)
  minSelect  Int          @default(0)
  maxSelect  Int          @default(1)
  options    Json // [{ "name": "หวานน้อย", "priceAdd": 0 }]
  sortOrder  Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
  @@map("modifiers")
}

// ─── TABLES ──────────────────────────────────────────────

model Table {
  id        String      @id @default(cuid())
  branchId  String
  name      String // เช่น "A1", "โต๊ะ 5", "VIP Room"
  zone      String? // เช่น "Indoor", "Outdoor", "Bar"
  capacity  Int         @default(4)
  status    TableStatus @default(AVAILABLE)
  qrCodeUrl String? // URL สำหรับ QR self-order
  qrToken   String?     @unique // token ที่ใช้ใน self-order URL
  posX      Int? // สำหรับ floor plan (Phase 2)
  posY      Int?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  branch   Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  orders   Order[]
  sessions TableSession[]

  @@index([branchId])
  @@map("tables")
}

model TableSession {
  id         String             @id @default(cuid())
  tableId    String
  guestCount Int?
  note       String?
  status     TableSessionStatus @default(OPEN)
  totalSpend Decimal            @default(0) @db.Decimal(10, 2)
  openedAt   DateTime           @default(now())
  closedAt   DateTime?

  table  Table   @relation(fields: [tableId], references: [id])
  orders Order[] @relation("SessionOrders")

  @@index([tableId])
  @@index([status])
  @@map("table_sessions")
}

// ─── ORDERS ──────────────────────────────────────────────

model Order {
  id            String      @id @default(cuid())
  branchId      String
  tableId       String?
  sessionId     String?
  cashierId     String?
  type          OrderType   @default(DINE_IN)
  status        OrderStatus @default(PENDING)
  note          String?
  subtotal      Decimal     @default(0) @db.Decimal(10, 2)
  discountAmt   Decimal     @default(0) @db.Decimal(10, 2)
  discountNote  String?
  taxAmt        Decimal     @default(0) @db.Decimal(10, 2)
  total         Decimal     @default(0) @db.Decimal(10, 2)
  guestCount    Int?
  customerPhone String?
  receiptToken  String?     @unique
  receiptNo     String?     @unique
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  completedAt   DateTime?

  guestName       String? // ชื่อ guest สำหรับเรียกคิว
  memberAccountId String? // ถ้า order มาจาก member (self-order)
  checkoutMode    String? // "PAY_ONLINE" | "PAY_LATER" | "PAY_AT_COUNTER"

  cashier       TenantMembership? @relation("CashierOrders", fields: [cashierId], references: [id])
  branch        Branch            @relation(fields: [branchId], references: [id])
  memberAccount LoyaltyAccount?   @relation(fields: [memberAccountId], references: [id])
  table         Table?            @relation(fields: [tableId], references: [id])
  session       TableSession?     @relation("SessionOrders", fields: [sessionId], references: [id])
  items         OrderItem[]
  payments      Payment[]
  queueTicket   QueueTicket?
  couponUsages  CouponUsage[]

  @@index([branchId])
  @@index([tableId])
  @@index([sessionId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id         String          @id @default(cuid())
  orderId    String
  menuItemId String
  name       String // snapshot ชื่อเมนู ณ ตอนสั่ง
  unitPrice  Decimal         @db.Decimal(10, 2)
  qty        Int             @default(1)
  modifiers  Json            @default("[]") // snapshot modifier ที่เลือก
  note       String?
  status     OrderItemStatus @default(PENDING)
  voidedById String? // user ที่ทำ void
  voidReason String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@index([status])
  @@map("order_items")
}

// ─── PAYMENTS ────────────────────────────────────────────

model Payment {
  id           String        @id @default(cuid())
  orderId      String
  method       PaymentMethod
  amount       Decimal       @db.Decimal(10, 2)
  cashReceived Decimal?      @db.Decimal(10, 2) // กรณีจ่ายเงินสด
  changeAmt    Decimal?      @db.Decimal(10, 2)
  status       PaymentStatus @default(PENDING)
  gatewayRef   String? // Omise charge ID หรือ reference อื่นๆ
  gatewayData  Json? // raw response จาก gateway
  confirmedAt  DateTime?
  refundAmt    Decimal?      @db.Decimal(10, 2)
  refundRef    String?
  refundedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
  @@map("payments")
}

// ─── SHIFTS ──────────────────────────────────────────────

model Shift {
  id           String    @id @default(cuid())
  branchId     String
  // userId       String
  openCash     Decimal   @db.Decimal(10, 2) // เงินเปิดกะ
  closeCash    Decimal?  @db.Decimal(10, 2) // เงินนับปิดกะ
  expectedCash Decimal?  @db.Decimal(10, 2) // คำนวณจากยอดขาย
  difference   Decimal?  @db.Decimal(10, 2) // closeCash - expectedCash
  note         String?
  openedAt     DateTime  @default(now())
  closedAt     DateTime?
  membershipId String

  membership TenantMembership @relation(fields: [membershipId], references: [id])

  branch Branch @relation(fields: [branchId], references: [id])
  // user   User   @relation(fields: [userId], references: [id])

  @@index([branchId])
  @@index([membershipId])
  // @@index([userId])
  @@map("shifts")
}

// ─── STOCK LOGS ──────────────────────────────────────────

model StockLog {
  id         String         @id @default(cuid())
  menuItemId String
  delta      Int // บวก = เพิ่ม, ลบ = ลด
  qtyAfter   Int // stock หลังเปลี่ยน
  reason     StockLogReason
  orderId    String? // มีถ้า reason = ORDER_DEDUCT หรือ VOID_RESTORE
  note       String?
  createdAt  DateTime       @default(now())

  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([menuItemId])
  @@index([createdAt])
  @@map("stock_logs")
}

model QueueTicket {
  id          String      @id @default(cuid())
  branchId    String
  orderId     String      @unique
  ticketNo    Int
  displayCode String?
  status      QueueStatus @default(WAITING)
  calledAt    DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())

  branch Branch @relation(fields: [branchId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id])

  @@index([branchId, status])
  @@index([branchId, ticketNo])
  @@map("queue_tickets")
}

// ─── CUSTOMERS (CRM lite) ────────────────────────────────

// model Customer {
//   id          String   @id @default(cuid())
//   tenantId    String
//   phone       String // จาก PromptPay
//   name        String?
//   visitCount  Int      @default(1)
//   totalSpend  Decimal  @default(0) @db.Decimal(12, 2)
//   lastVisitAt DateTime @default(now())
//   note        String?
//   createdAt   DateTime @default(now())
//   updatedAt   DateTime @updatedAt

//   tenant  Tenant          @relation(fields: [tenantId], references: [id])
//   loyalty LoyaltyAccount?

//   @@unique([tenantId, phone])
//   @@index([tenantId])
//   @@map("customers")
// }

model LoyaltyAccount {
  id          String    @id @default(cuid())
  tenantId    String
  phone       String
  name        String? // ชื่อที่ลงทะเบียน — ย้ายมาจาก Customer
  note        String? // internal note — ย้ายมาจาก Customer
  tierId      String? // ← ต้อง nullable (ดูข้อ 2)
  points      Int       @default(0)
  totalEarned Int       @default(0)
  totalSpend  Decimal   @default(0) @db.Decimal(12, 2)
  visitCount  Int       @default(0)
  lastVisitAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant         Tenant             @relation(fields: [tenantId], references: [id])
  tier           LoyaltyTierConfig? @relation(fields: [tierId], references: [id], onDelete: SetNull)
  transactions   PointTransaction[]
  memberSessions MemberSession[]
  couponUsages   CouponUsage[]
  orders         Order[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([tierId])
  @@map("loyalty_accounts")
}

model LoyaltyTierConfig {
  id         String   @id @default(cuid())
  tenantId   String
  name       String // "ทอง", "Gold", "VIP" — ตั้งเองได้
  minPoints  Int // แต้มขั้นต่ำเพื่อเข้า tier นี้
  multiplier Decimal  @db.Decimal(4, 2) // ตัวคูณแต้ม เช่น 1.5 = ได้แต้ม x1.5
  color      String? // hex สำหรับ badge UI เช่น "#FFD700"
  sortOrder  Int      @default(0) // เรียงลำดับ tier
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  accounts LoyaltyAccount[]
  coupons  Coupon[]

  @@index([tenantId])
  @@map("loyalty_tier_configs")
}

model PointTransaction {
  id        String    @id @default(cuid())
  accountId String
  orderId   String?
  branchId  String?
  type      PointType
  delta     Int
  balance   Int
  note      String?
  createdAt DateTime  @default(now())

  account LoyaltyAccount @relation(fields: [accountId], references: [id])
  branch  Branch?        @relation(fields: [branchId], references: [id])

  @@index([accountId])
  @@index([orderId])
  @@index([branchId])
  @@map("point_transactions")
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String
  name        String // "หัวหน้ากะ", "Supervisor"
  baseRole    UserRole // OWNER/MANAGER/CASHIER/KITCHEN — ใช้เป็น hierarchy fallback
  permissions String[] @default([]) // ["order:void", "menu:write", ...]
  isSystem    Boolean  @default(false) // true = built-in ลบ/แก้ไม่ได้
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // users  User[]
  memberships TenantMembership[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  tenantId  String
  code      String // 6 หลัก (log ใน dev)
  expiresAt DateTime // 5 นาที
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  attempts  Int      @default(0)

  @@index([phone, tenantId, createdAt])
  @@map("otp_codes")
}

// Member token แยกจาก Staff JWT
model MemberSession {
  id        String   @id @default(cuid())
  accountId String
  token     String   @unique // random UUID
  expiresAt DateTime // 30 วัน
  createdAt DateTime @default(now())

  account LoyaltyAccount @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@map("member_sessions")
}
