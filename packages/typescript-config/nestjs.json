{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "ES2023",
    "removeComments": true,
    "sourceMap": true,
    "noEmit": false,
    "declaration": false,
    "declarationMap": false,
    "resolvePackageJsonExports": true
  }
}
