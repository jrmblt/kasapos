{
  "name": "serva",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "db:generate": "bun run --filter @repo/database db:generate",
    "db:push": "bun run --filter @repo/database db:push",
    "db:deploy": "bun run --filter @repo/database db:deploy",
    "db:migrate": "bun run --filter @repo/database db:migrate",
    "db:reset": "bun run --filter @repo/database db:reset",
    "db:studio": "bun run --filter @repo/database db:studio",
    "db:seed": "bun run --filter @repo/database db:seed",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check-types": "turbo run check-types",
    "knip": "knip",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@commitlint/types": "^19.8.0",
    "@tailwindcss/postcss": "^4",
    "knip": "^5.51.0",
    "lefthook": "^1.11.13",
    "shadcn": "^4.1.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "turbo": "^2.8.20",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
